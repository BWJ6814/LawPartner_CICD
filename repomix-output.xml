        }
    };

    const fetchNotificationList = async () => {
        const token = localStorage.getItem('accessToken');
        if (!token) return;

        try {
            // 방금 백엔드에 만든 리스트 가져오기 API 호출
            const response = await api.get('/api/mypage/notifications/list');
