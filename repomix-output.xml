const panel = {
    background: "#111c34",
    border: "1px solid rgba(255,255,255,0.08)",
    borderRadius: 22,
    padding: 40,
    boxShadow: "0 12px 50px rgba(0,0,0,0.35)",
    color: "#fff",
};

