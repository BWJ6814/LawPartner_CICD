const Footer = () => {
    return (
        // py-6 -> py-4 (전체 높이 축소)
        <footer className="bg-[#0f172a] text-white py-4 border-t border-slate-800">
            <div className="max-w-7xl mx-auto px-4 flex flex-col items-center text-center">

                {/* 1. 사이트 명 & 로고 (여백 mb-4 -> mb-1로 축소) */}
