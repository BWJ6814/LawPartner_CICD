                if (!room.getLawyerNo().equals(lawyerNo)) {
                        throw new RuntimeException("변호사만 종료할 수 있습니다.");
                }
                room.setProgressCode("ST05"); // 종료 상태로 변경

                ChatMessageDTO statusMsg = ChatMessageDTO.builder()
                                .roomId(roomId)
                                .msgType("STATUS_CHANGE")
