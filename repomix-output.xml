package com.example.backend_main.dto.HSH_DTO;

import lombok.*;

@Getter
@Setter
@Builder
@AllArgsConstructor
@NoArgsConstructor
public class TokenDTO {
    // "Bearer"라는 인증 방식 명시
    private String grantType;
    // 실제 문을 열 때 쓰는 단거리 통행증
