    fontSize: 20,
    fontWeight: 900,
    marginBottom: 14,
};

const subject = {
    fontSize: 34,
    fontWeight: 900,
    lineHeight: 1.15,
    marginBottom: 16,
};

const metaRow = {
    display: "flex",
    alignItems: "center",
    gap: 10,
    flexWrap: "wrap",
};

const badge = {
    display: "inline-flex",
    alignItems: "center",
    height: 30,
