            // 1. 처음 켜지면 무조건 한 번 긁어오기
            fetchAll();

            // 2. [보험용] 혹시 웹소켓 끊길까 봐 30초마다 긁어오는 건 유지 (필수 아님)
            timer = setInterval(() => {
                fetchAll();
