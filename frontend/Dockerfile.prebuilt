# 로컬(또는 메모리 넉넉한 PC)에서 먼저: cd frontend && npm ci && npm run build
# 서버의 frontend/ 아래에 build/ 폴더가 있을 때만 사용. EC2에서 npm run build 가 도저히 끝나지 않을 때 대안.
FROM nginx:1.27-alpine
WORKDIR /usr/share/nginx/html
COPY build/ ./
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
